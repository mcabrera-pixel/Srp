# RAG-Anything Service Config
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...

# Modelo para visión/multimodal (RAG-Anything)
VISION_MODEL=google/gemini-2.5-flash-preview-05-20
TEXT_MODEL=google/gemini-2.5-flash-preview-05-20
EMBEDDING_MODEL=text-embedding-3-small

# Directorio de trabajo para RAG
RAG_WORKING_DIR=./rag_data

# Puerto del servicio
PORT=8100
