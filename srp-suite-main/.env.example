# ============================================================================
# SRP Suite - Variables de Entorno
# Copia este archivo a .env y completa los valores
# ============================================================================

# ─── LLM Providers ──────────────────────────────────────────────────────────
MINIMAX_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ─── Audio (Whisper) ────────────────────────────────────────────────────────
# Usa la misma OPENAI_API_KEY para transcripción de audio

# ─── WhatsApp (Wasender) ────────────────────────────────────────────────────
WASENDER_API_KEY=
WASENDER_DEVICE_ID=

# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Ollama (opcional - modelos locales) ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
