# NLM Daemon Configuration

# Mode: local (scan input/) or api (poll Worker API)
MODE=local

# Polling interval (seconds)
POLL_INTERVAL=30

# Worker API (for api mode)
API_BASE_URL=http://localhost:8787
API_TOKEN=

# Directories (for local mode)
INPUT_DIR=./input
OUTPUT_DIR=./output
LOG_DIR=./logs
PROCESSED_DIR=./processed
